# Supabase — pulled from Vercel: `vercel link && vercel env pull .env.local`
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — NEVER expose to browser. Optional in the demo phase
# (v1 permissive RLS lets the anon key handle server writes).
SUPABASE_SERVICE_ROLE_KEY=

# App URL (used for redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
